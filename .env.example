# SQMeter device URL (required)
SQMETER_BASE_URL=http://192.168.1.100

# Alpaca HTTP server
ALPACA_HTTP_BIND=0.0.0.0
ALPACA_HTTP_PORT=11111

# Alpaca UDP discovery
ALPACA_DISCOVERY_PORT=32227

# Polling
POLL_INTERVAL_SECONDS=5
STALE_AFTER_SECONDS=30

# Safety defaults (fail unsafe if unreachable)
FAIL_CLOSED=true
CONNECTED_ON_STARTUP=true

# Cloud cover thresholds (percent)
CLOUD_COVER_UNSAFE_PERCENT=80
CLOUD_COVER_CAUTION_PERCENT=50

# Require all sensors to be healthy (status=0)
REQUIRE_LIGHT_SENSOR_STATUS_OK=true
REQUIRE_ENVIRONMENT_STATUS_OK=true
REQUIRE_IR_TEMPERATURE_STATUS_OK=true

# Optional hard limits (uncomment to enable)
# SQM_MIN_SAFE=18.0
# HUMIDITY_MAX_SAFE=90
# DEWPOINT_MARGIN_MIN_C=3.0

# Manual override: auto | force_safe | force_unsafe
MANUAL_OVERRIDE=auto

# Log verbosity: debug | info | warn | error
LOG_LEVEL=info
